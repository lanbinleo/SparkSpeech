{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SparkSpeech",
  "version": "0.1.0",
  "identifier": "com.leo.sparkspeech",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SparkSpeech",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "SparkSpeech Overlay",
        "url": "/?overlay=1",
        "width": 260,
        "height": 60,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
